{
  "name": "dash-contract-fee-estimator",
  "version": "1.0.0",
  "description": "Estimate Dash Platform data contract registration fees",
  "type": "module",
  "main": "./dist-lib/index.cjs",
  "module": "./dist-lib/index.mjs",
  "types": "./dist-lib/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist-lib/index.mjs",
      "require": "./dist-lib/index.cjs",
      "types": "./dist-lib/types/index.d.ts"
    }
  },
  "files": [
    "dist-lib/"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:lib": "BUILD_LIB=true vite build && tsc -p tsconfig.lib.json",
    "build:all": "npm run build && npm run build:lib",
    "preview": "vite preview",
    "test": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
